# Shared tool and base-image version pins - single source of truth.
# Loaded by Taskfile.yml via dotenv and consumed by CI workflows.

# Lint and security tooling
GOLANGCILINT_VERSION=v2.8.0
GOVULNCHECK_VERSION=v1.4.0
TYPOS_VERSION=1.44.0
# crate-ci/typos publishes no checksums; this is our own pin of the
# x86_64-unknown-linux-musl release asset. Recompute when bumping TYPOS_VERSION:
#   curl -sfLO <release asset> && shasum -a 256 typos-*.tar.gz
TYPOS_SHA256_LINUX_X86_64=1b788b7d764e2f20fe089487428a3944ed218d1fb6fcd8eac4230b5893a38779
YAMLLINT_VERSION=1.35.1

# Task version installed by CI (local installs may differ)
TASK_VERSION=3.49.1

# Trivy base image (aquasec/trivy) the adapter image is built FROM.
# Named like harbor-next's pin; must NOT be TRIVY_VERSION because dotenv exports
# these into every task's environment and the scanner itself reads TRIVY_VERSION
# (pkg/harbor/model.go), which would poison unit tests and `task run`.
TRIVY_BASE_IMAGE_VERSION=0.72.0
