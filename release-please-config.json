{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "bootstrap-sha": "a187732b07e325c7c6067e43b256c53e1b005e86",
  "pull-request-title-pattern": "chore: release ${version}",
  "release-type": "go",
  "always-update": true,
  "include-v-in-tag": true,
  "exclude-paths": [
    ".github",
    "docs"
  ],
  "changelog-sections": [
    {
      "type": "feat",
      "section": "Features"
    },
    {
      "type": "fix",
      "section": "Bug Fixes"
    },
    {
      "type": "perf",
      "section": "Performance Improvements"
    },
    {
      "type": "upstream",
      "section": "Upstream"
    },
    {
      "type": "revert",
      "section": "Reverts"
    },
    {
      "type": "refactor",
      "section": "Code Refactoring"
    },
    {
      "type": "docs",
      "section": "Documentation"
    },
    {
      "type": "test",
      "section": "Tests",
      "hidden": true
    },
    {
      "type": "chore",
      "section": "Miscellaneous",
      "hidden": true
    },
    {
      "type": "ci",
      "section": "CI/CD",
      "hidden": true
    },
    {
      "type": "build",
      "section": "Build System",
      "hidden": true
    }
  ],
  "packages": {
    ".": {
      "extra-files": [
        {
          "type": "generic",
          "path": "helm/harbor-scanner-trivy/Chart.yaml"
        },
        {
          "type": "generic",
          "path": "helm/harbor-scanner-trivy/values.yaml"
        }
      ]
    }
  },
  "bump-minor-pre-major": true
}
